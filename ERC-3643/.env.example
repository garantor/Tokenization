# Deployment profile: dev or prod
DEPLOY_PROFILE=dev

# Number of confirmations to wait for each state-changing transaction
DEPLOY_CONFIRMATIONS=1

# Core token configuration
TREX_OWNER=0x0000000000000000000000000000000000000001
TREX_TOKEN_NAME=Treasury Bill Token
TREX_TOKEN_SYMBOL=TBT
TREX_TOKEN_DECIMALS=0
TREX_SALT=ngn-tbill-series-2026q2

# Claim configuration
# Accepts plain string (hashed with ethers.utils.id) or hex value.
TREX_CLAIM_TOPIC=KYC_CLAIM
# Comma-separated list. Each entry can be plain string or hex.
TREX_CLAIM_ISSUER_CLAIMS=KYC_CLAIM

# Claim issuer configuration
# If TREX_CLAIM_ISSUER_ADDRESS is omitted, script deploys a new ClaimIssuer.
TREX_CLAIM_ISSUER_ADDRESS=
TREX_CLAIM_ISSUER_OWNER=0x0000000000000000000000000000000000000001
TREX_CLAIM_SIGNER=0x0000000000000000000000000000000000000002

# Optional pre-existing components. Leave empty to deploy/derive within factory flow.
TREX_IRS_ADDRESS=
TREX_ONCHAINID_ADDRESS=

# Agent lists (comma-separated addresses)
TREX_IR_AGENTS=0x0000000000000000000000000000000000000003
TREX_TOKEN_AGENTS=0x0000000000000000000000000000000000000004

# Optional compliance module setup
# Comma-separated addresses
TREX_COMPLIANCE_MODULES=
# JSON array of hex calldata, length must be <= TREX_COMPLIANCE_MODULES length
TREX_COMPLIANCE_SETTINGS_JSON=[]

# Output directory for deployment artifacts
TREX_OUTPUT_DIR=./deployments
