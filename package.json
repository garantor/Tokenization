{
  "name": "erc3643-backend",
  "version": "1.0.0",
  "description": "ERC-3643 Tokenization Backend",
  "main": "dist/server.js",
  "scripts": {
    "start": "ts-node src/server.ts",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "jest --config ./jest.config.json tests/unit",
    "test:integration": "jest --config ./jest.config.json tests/integration",
    "test:e2e": "jest --config ./jest.e2e.json tests/e2e",
    "blockchain:setup": "concurrently \"npx hardhat node\" \"wait-on tcp:8545 && cd ERC-3643 && npx hardhat run scripts/deploy-trex.ts --network localhost && ts-node ../scripts/sync-env.ts\""
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.5.0",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "hardhat": "^2.22.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "viem": "^2.9.16",
    "wait-on": "^9.0.4"
  }
}
