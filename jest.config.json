{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": "\\.(test|spec)\\.ts$",
  "testPathIgnorePatterns": [".e2e-spec.ts$"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testTimeout": 10000,
  "globals": {
    "ts-jest": {
      "tsconfig": "tsconfig.json"
    }
  }
}
